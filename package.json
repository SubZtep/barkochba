{
  "name": "barkochba",
  "description": "Kaja CLI",
  "version": "0.0.5",
  "type": "module",
  "private": true,
  "bin": {
    "kaja": "./dist/cli.js"
  },
  "scripts": {
    "start": "bun run cli.tsx",
    "build": "tsc",
    "test": "bun test",
    "lint": "bunx --bun @biomejs/biome check --config-path=. --write --unsafe"
  },
  "//": [
    "marked is pinned to ^15 (not latest) because marked-terminal@7 requires marked >=1 <16",
    "react-devtools-core is ink's optional devtools peer; it must be installed for `bun build --compile` to bundle ink (inert at runtime unless DEV=true)"
  ],
  "dependencies": {
    "dedent": "^1.7.2",
    "env-paths": "^4.0.0",
    "ink": "^7.1.1",
    "ink-gradient": "^4.0.1",
    "ink-scroll-list": "^0.4.1",
    "ink-scroll-view": "^0.3.7",
    "marked": "^15",
    "marked-terminal": "^7.3.0",
    "meow": "^14.1.0",
    "openai": "^6.48.0",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "string-width": "^8.2.2",
    "terminal-link": "^5.0.0",
    "tinyclip": "^0.1.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/marked-terminal": "^6.1.1",
    "@types/react": "^19.2.17",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "@types/bun": "^1.3.3"
  },
  "peerDependenciesMeta": {
    "@types/bun": {
      "optional": true
    }
  }
}
